{
    "name": "shahkochaki/moadian",
    "description": "Laravel package for interacting with the Iranian Tax Authority (Moadian) API",
    "type": "library",
    "keywords": [
        "laravel",
        "moadian",
        "iranian-tax",
        "tax"
    ],
    "homepage": "https://github.com/shahkochaki/moadian",
    "license": "MIT",
    "authors": [
        {
            "name": "Shahkochaki",
            "email": "ali.shahkochaki7@gmail.com"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "ext-openssl": "*",
        "guzzlehttp/guzzle": "^7.0",
        "ramsey/uuid": "^4.2",
        "symfony/cache": "^5.3|^6.0",
        "phpseclib/phpseclib": "^3.0",
        "firebase/php-jwt": "^6.9",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0",
        "nesbot/carbon": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Shahkochaki\\Moadian\\": "src/",
            "Shahkochaki\\Moadian\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0",
        "mockery/mockery": "^1.5",
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Shahkochaki\\Moadian\\MoadianServiceProvider"
            ],
            "aliases": {
                "Moadian": "Shahkochaki\\Moadian\\Facades\\Moadian"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}